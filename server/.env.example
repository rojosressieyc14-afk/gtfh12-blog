SERVER_PORT=8080
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=blog_system
# 生产环境请替换为至少 32 位随机字符串
JWT_SECRET=change-me-secret
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
WEB_ORIGIN=http://localhost:5173
ADMIN_ORIGIN=http://localhost:5174
# 逗号分隔的 CORS 来源，优先级高于 WEB_ORIGIN/ADMIN_ORIGIN
CORS_ORIGINS=
GIN_MODE=release
UPLOAD_DIR=./uploads
# DeepSeek AI 面试官
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 日志级别: debug / info / warn / error
LOG_LEVEL=info
# 日志格式: text / json
LOG_FORMAT=text
