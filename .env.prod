# PulseBlog 生产环境配置
# 复制此文件为 .env 并修改以下配置

# MySQL
DB_PASSWORD=please_change_this_password
DB_NAME=blog_system

# JWT 密钥（至少 32 位随机字符）
JWT_SECRET=please_change_this_to_a_random_secret_key

# 默认管理员
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=please_change_admin_password

# 前端来源（部署后替换为实际域名）
WEB_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001
